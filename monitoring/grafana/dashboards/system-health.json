{
  "title": "System Health",
  "uid": "system-health",
  "version": 1,
  "tags": ["infrastructure", "system"],
  "schemaVersion": 39,
  "panels": [
    {
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "orange" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 80, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/var/lib\"} / node_filesystem_size_bytes{mountpoint=\"/var/lib\"})",
          "legendFormat": "Disk"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 85, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "none" }
        }
      }
    },
    {
      "title": "CPU Load Average",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m" },
        { "expr": "node_load5", "legendFormat": "5m" },
        { "expr": "node_load15", "legendFormat": "15m" }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[1m])", "legendFormat": "tx {{device}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "PG Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"gravure_db\"} / (pg_stat_database_blks_hit{datname=\"gravure_db\"} + pg_stat_database_blks_read{datname=\"gravure_db\"}) * 100",
          "legendFormat": "Cache Hit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 95, "color": "orange" },
              { "value": 90, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "PG Active Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"gravure_db\"}",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 20, "color": "orange" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "PG Deadlocks",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=\"gravure_db\"}[5m])",
          "legendFormat": "deadlocks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "orange" },
              { "value": 0.5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1000000000, "color": "orange" },
              { "value": 2000000000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 90, "color": "orange" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Connected Clients",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "orange" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[1m]) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"}",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "HTTP Probe Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "avg(probe_success) * 100",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 99, "color": "orange" },
              { "value": 95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "HTTP Probe Duration (Avg)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 4, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "avg(probe_duration_seconds)",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "HTTP Probes by Endpoint",
      "type": "stat",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "count(probe_success == 1) or vector(0)",
          "legendFormat": "Up"
        },
        {
          "expr": "count(probe_success == 0) or vector(0)",
          "legendFormat": "Down"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "none" }
        }
      }
    },
    {
      "title": "Orders by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "orders_total",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Jobs by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "jobs_total",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Ink Batches by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "ink_batches_total",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Cylinders by Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "cylinders_total",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Backend Logs (Loki)",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 48 },
      "targets": [
        {
          "expr": "{service=\"backend\"}",
          "legendFormat": ""
        }
      ],
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    }
  ]
}
