    "bcryptjs": "^2.4.3",
    "bullmq": "^5.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "sharp": "^0.35.0",
