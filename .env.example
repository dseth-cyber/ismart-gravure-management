# Cloudflare Tunnel token for production profile
# Generate at https://one.dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels
# Copy this file to .env and set your token before running:
#   docker compose --profile production up -d
CF_TUNNEL_TOKEN=your_tunnel_token_here

# Required Docker Secrets (create files in ./secrets/ directory):
# All .txt files in ./secrets/ are gitignored.
#
# Existing secrets (auto-generated during initial setup):
# - db_url.txt          : PostgreSQL connection URL
# - db_password.txt     : PostgreSQL password
# - redis_url.txt       : Redis connection URL (with password)
# - redis_password.txt  : Redis password
# - jwt_secret.txt      : JWT signing secret (64 hex chars)
# - jwt_refresh_secret.txt : JWT refresh secret (64 hex chars)
# - api_keys.txt        : Comma-separated API keys for machine-to-machine auth
# - minio_access_key.txt : MinIO access key
# - minio_secret_key.txt : MinIO secret key
# - grafana_password.txt: Grafana admin password
